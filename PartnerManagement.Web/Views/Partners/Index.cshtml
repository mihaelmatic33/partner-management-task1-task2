@model PartnerManagement.Web.Models.PartnerListViewModel
@{
    ViewData["Title"] = "Partneri";
}

<div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
    <div>
        <div class="page-hero__eyebrow">Upravljanje partnerima</div>
        <h1 class="h3 mb-1">Partneri osiguravajućeg društva</h1>
        <p class="text-muted mb-0">Pregled svih partnera, detalja i polica na jednom mjestu.</p>
    </div>
    <div class="page-hero__actions mt-3 mt-md-0">
        <a class="btn btn-primary" asp-controller="Partners" asp-action="Create">Unos novog partnera</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

<div class="card shadow-sm border-0 mb-4" id="partners-list-root" data-list-url="@Url.Action("List", "Partners")" data-highlight-id="@Model.HighlightPartnerId" data-policy-create-url="@Url.Action("Create", "Policies")" data-policy-edit-url-template="@Url.Action("Edit", "Policies", new { id = "__POLICY_ID__" })">
    <div class="card-body">
        <div class="alert alert-success d-none" id="partners-inline-success" role="alert"></div>
        <form id="partners-filter-form" class="mb-0" novalidate>
            <div class="form-row align-items-end mb-2">
                <div class="form-group col-lg-7 mb-2">
                    <label for="partners-search" class="small font-weight-bold">Pretraga</label>
                    <input type="text" class="form-control" id="partners-search" placeholder="Ime, partner number, PIN, iznos police" />
                </div>
                <div class="form-group col-lg-5 mb-2 text-lg-right">
                    <button type="button" class="btn btn-outline-primary" data-toggle="collapse" data-target="#advanced-filters" aria-expanded="false" aria-controls="advanced-filters">Filteri</button>
                </div>
            </div>

            <div class="collapse" id="advanced-filters">
                <div class="filter-panel rounded p-3 mb-2">
                    <div class="form-row">
                        <div class="form-group col-lg-4 mb-2">
                    <label for="partners-name-filter" class="small font-weight-bold">Ime partnera</label>
                    <input type="text" class="form-control" id="partners-name-filter" placeholder="npr. Marko Marić" />
                </div>
                <div class="form-group col-lg-2 mb-2">
                    <label for="partners-pin-filter" class="small font-weight-bold">Croatian PIN</label>
                    <input type="text" class="form-control" id="partners-pin-filter" maxlength="11" />
                </div>
                <div class="form-group col-lg-3 mb-2">
                    <label for="partners-created-from" class="small font-weight-bold">Date created</label>
                    <div class="d-flex align-items-center">
                        <input type="date" class="form-control" id="partners-created-from" />
                        <span class="mx-2 text-muted">-</span>
                        <input type="date" class="form-control" id="partners-created-to" />
                    </div>
                </div>
                </div>
                    <div class="form-row align-items-end">
                        <div class="form-group col-md-3 mb-2">
                            <label for="partners-amount-min" class="small font-weight-bold">Iznos police od</label>
                            <input type="number" class="form-control" id="partners-amount-min" step="0.01" min="0" />
                        </div>
                        <div class="form-group col-md-3 mb-2">
                            <label for="partners-amount-max" class="small font-weight-bold">Iznos police do</label>
                            <input type="number" class="form-control" id="partners-amount-max" step="0.01" min="0" />
                        </div>
                        <div class="form-group col-md-2 mb-2">
                            <div class="form-check mt-4">
                                <input type="checkbox" class="form-check-input" id="partners-only-active" />
                                <label class="form-check-label" for="partners-only-active">Samo aktivni</label>
                            </div>
                        </div>
                        <div class="form-group col-md-4 mb-2 text-md-right">
                            <div class="filter-actions">
                                <button type="submit" class="btn btn-primary">Primijeni filtere</button>
                                <button type="button" class="btn btn-outline-secondary" id="partners-reset-filters">Reset</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="partners-table">
                <thead class="thead-light">
                    <tr>
                        <th>FullName</th>
                        <th>PartnerNumber</th>
                        <th>CroatianPIN</th>
                        <th>PartnerType</th>
                        <th>CreatedAtUtc</th>
                        <th>IsForeign</th>
                        <th>Aktivan</th>
                        <th>Gender</th>
                        <th>Police</th>
                        <th>Iznos polica</th>
                        <th class="text-right partner-actions-column">Akcije</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <div id="partners-loading" class="text-center text-muted py-3 d-none">Učitavanje partnera...</div>
        <div id="partners-empty" class="text-center text-muted py-3 d-none">Nema rezultata za zadane filtere.</div>
        <div id="partners-end" class="text-center text-muted py-3 d-none">Nema više partnera.</div>
        <div id="partners-scroll-anchor" class="py-1"></div>
    </div>
</div>

<button type="button" class="floating-policy-cta d-none" id="floating-policy-cta">+ Dodaj policu</button>

<div class="modal fade" id="partnerDetailsModal" tabindex="-1" role="dialog" aria-labelledby="partnerDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="partnerDetailsModalLabel">Detalji partnera</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="partner-details-content">
                <div class="text-center py-4 text-muted">Učitavanje...</div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="policyCreateModal" tabindex="-1" role="dialog" aria-labelledby="policyCreateModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="policyCreateModalLabel">Unos police</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="policy-form" asp-controller="Policies" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="policy-id" name="PolicyId" />
                    <input type="hidden" id="policy-partner-id" name="PartnerId" />
                    <div class="alert alert-danger d-none" id="policy-form-errors"></div>
                    <div class="form-group d-none" id="policy-partner-picker-group">
                        <label for="policy-partner-search" class="font-weight-bold">Odaberi partnera (po imenu)</label>
                        <input type="text" class="form-control" id="policy-partner-search" placeholder="Upiši ime partnera" autocomplete="off" />
                        <select class="form-control mt-2" id="policy-partner-select" size="6"></select>
                        <span class="text-danger small d-block" id="policy-partner-error"></span>
                    </div>
                    <div class="form-group" id="policy-partner-static-group">
                        <label class="font-weight-bold">Partner</label>
                        <input type="text" class="form-control" id="policy-partner-name" readonly />
                    </div>
                    <div class="form-group">
                        <label for="policy-number">Broj police</label>
                        <input type="text" class="form-control" id="policy-number" name="PolicyNumber" maxlength="15" />
                        <span class="text-danger small d-block" id="policy-number-error"></span>
                    </div>
                    <div class="form-group">
                        <label for="policy-amount">Iznos police</label>
                        <input type="number" class="form-control" id="policy-amount" name="PolicyAmount" step="0.01" min="0.01" />
                        <span class="text-danger small d-block" id="policy-amount-error"></span>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Spremi policu</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/partners.js" asp-append-version="true"></script>
}